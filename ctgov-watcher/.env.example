# Copy to `.env` and fill in your values. NEVER commit the real .env file.

# Where the trial-impact service is reachable.
MAIN_SERVICE_URL=http://localhost:8000

# Shared secret used to HMAC-sign webhooks. MUST match the trial-impact service's
# WATCHER_SHARED_SECRET.
WATCHER_SHARED_SECRET=change-me-to-a-long-random-string

# Trials to watch + their static enrichment metadata.
WATCHLIST_PATH=watchlist.json

# Where the last-seen state SQLite file lives.
STATE_PATH=watcher_state.db

# Seconds between poll cycles (default 1h). ClinicalTrials.gov data changes daily
# at most, so there is no need to poll aggressively.
POLL_INTERVAL_SECONDS=3600

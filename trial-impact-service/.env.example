# Copy to `.env` and fill in your values. NEVER commit the real .env file.

# --- Devin (runs the biophysical simulation) --------------------------------
# Devin API key — used to create and poll simulation sessions.
# Create one at https://app.devin.ai/settings/api-keys
DEVIN_API_KEY=your-devin-api-key

# Repo Devin clones to run the pipeline (app/simulation.py: docking + PK/PD).
SIM_REPO_URL=https://github.com/noahlin17/trial-impact

# The exact commit Devin checks out before running. REQUIRED for real runs: an
# unpinned checkout is not reproducible and code_patched cannot be verified against
# it, so the service refuses to launch a session without it. Set it to a full commit
# SHA. (run_real.py / compare_estimators.py fall back to your local `git rev-parse
# HEAD` when this is unset.)
SIM_REPO_COMMIT=

# Devin API base — override only for testing against a fake/mock server.
# DEVIN_API_BASE=https://api.devin.ai/v1

# --- Trigger authentication -------------------------------------------------
# Shared secret the ctgov-watcher signs webhooks with (HMAC-SHA256). Leave empty
# to disable signature verification (dev only).
WATCHER_SHARED_SECRET=change-me-to-a-long-random-string

# --- Output: Slack (optional) -----------------------------------------------
# Incoming-webhook URL; alerts on market-moving readouts are POSTed here.
SLACK_WEBHOOK_URL=

# --- Output: email (optional) -----------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Market model -----------------------------------------------------------
# Path to the sponsor→ticker/competitor map.
TICKERS_PATH=tickers.json
# |PoS delta| at/above which an event is market-moving and an alert fires.
MARKET_MOVING_THRESHOLD=0.10

# --- Storage ----------------------------------------------------------------
DATABASE_PATH=/data/trial_impact.db
